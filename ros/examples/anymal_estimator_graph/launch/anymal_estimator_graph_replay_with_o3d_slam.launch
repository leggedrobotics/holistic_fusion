<?xml version="1.0" encoding="UTF-8"?>
<launch>
    <!-- Config -->
    <arg name="core_graph_param_file"
         default="$(find anymal_estimator_graph)/config/core/core_graph_params_gnss.yaml"/>
    <arg name="anymal_graph_param_file"
         default="$(find anymal_estimator_graph)/config/anymal_specific/anymal_graph_params_gnss.yaml"/>

    <!-- Input Topics -->
    <arg name="imu_topic_name" default="/sensors/imu"/>
    <arg name="lidar_odometry_topic_name"
         default="/open3d_slam/scan2map_odometry"/>  <!-- /open3d_slam/scan2map_odometry  /compslam_lio/odom_aft_mapped_to_init_CORRECTED  -->

    <!-- Launch SE node -->
    <include file="$(find anymal_estimator_graph)/launch/anymal_estimator_graph_replay.launch">
        <!-- Config -->
        <arg name="core_graph_param_file" value="$(arg core_graph_param_file)"/>
        <arg name="anymal_graph_param_file" value="$(arg anymal_graph_param_file)"/>
        <!-- Input Topics -->
        <arg name="imu_topic_name" value="$(arg imu_topic_name)"/>
        <arg name="lidar_odometry_topic_name" value="$(arg lidar_odometry_topic_name)"/>
    </include>

    <!-- O3D SLAM Config -->
    <arg name="launch_o3d_slam" default="true"/>
    <arg name="pointcloud_topic_name"
         default="/point_cloud_filter/lidar/point_cloud_filtered"/> <!-- /lidar/point_cloud -->
    <!--    <arg name="assumed_external_odometry_tracked_frame" default="imu_link"/>-->
    <!--    <arg name="o3d_prior_odometry_topic" default="/graph_msf/est_odometry_world_imu"/>-->
    <arg name="assumed_external_odometry_tracked_frame" default="base"/>
    <arg name="o3d_prior_odometry_topic" default="/state_estimator/odometry"/>

    <!-- Launch LIO -->
    <include file="$(find open3d_slam_ros)/launch/hike_launch.launch" if="$(arg launch_o3d_slam)">
        <arg name="cloud_topic" value="$(arg pointcloud_topic_name)"/>
        <arg name="launch_rviz" value="false"/>
        <arg name="assumed_external_odometry_tracked_frame" value="$(arg assumed_external_odometry_tracked_frame)"/>
        <arg name="odometry_topic" value="$(arg o3d_prior_odometry_topic)"/>
    </include>

     <arg name="description_name" default="anymal_description"/>
     <!-- Publish frequency -->
     <arg name="publish_frequency" default="100"/>
     <!-- Topic of the anymal state -->
     <arg name="anymal_state_subscriber_name" default="/state_estimator/anymal_state"/>

     <!-- Publish robot state (base) as TF -->
     <node name="anymal_tf_publisher" pkg="anymal_tf_publisher" type="anymal_tf_publisher_node" output="screen" respawn="true">
     <param name="subscribers/anymal_state/topic"      value="$(arg anymal_state_subscriber_name)"/>
     <param name="subscribers/anymal_state/queue_size" value="10"/>
     <param name="subscribers/anymal_state/latch"      value="false"/>    
     <param name="publishers/pose/topic"                  value="pose"/>
     <param name="publishers/pose/latch"                  value="false"/>
     <param name="publishers/pose/queue_size"             value="10"/>
     <param name="publishers/joint_state/topic"           value="joint_state"/>
     <param name="publishers/joint_state/latch"           value="false"/>
     <param name="publishers/joint_state/queue_size"      value="10"/>
     <param name="base_frame_id"                          value="base"/>
     <param name="odom_frame_id"                          value="odom"/>
     <param name="ignore_state"                           value="false"/>
     <param name="publish_frequency"                      value="$(arg publish_frequency)"/>
     <param name="robot_description"                      value="$(arg description_name)"/>
     </node>


</launch>
